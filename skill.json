  "author": "",
  "license": "MIT",
  "platforms": ["comfyui", "xiaoyunque", "jimeng", "google-imagen", "openai-dalle", "universal"],
  "capabilities": ["image-prompt-generation", "category-navigation", "memory-system"],
  "config": {
    "defaults": {
      "lang": "zh-CN",
      "platform": "comfyui",
      "memory_limit": 999,
      "recommend_count": 3
    }
  }
